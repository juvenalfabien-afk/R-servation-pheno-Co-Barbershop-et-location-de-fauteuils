# ── Supabase ──────────────────────────────────────────────────────
# Project Settings > API dans ton dashboard Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin ─────────────────────────────────────────────────────────
# Mot de passe que tu tapes pour accéder au dashboard
ADMIN_PASSWORD=choisis-un-mot-de-passe-fort

# Clé secrète pour signer le cookie de session (chaîne aléatoire longue)
# Génère-en une avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=une-chaine-aleatoire-de-64-caracteres-minimum

# ── EmailJS ───────────────────────────────────────────────────────
NEXT_PUBLIC_EMAILJS_KEY=ta-cle-emailjs
