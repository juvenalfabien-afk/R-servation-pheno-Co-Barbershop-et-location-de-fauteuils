# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings > API dans ton dashboard Supabase (supabase.com)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Mot de passe saisi sur /admin pour accéder au tableau de bord
ADMIN_PASSWORD=1141

# Clé secrète pour signer le cookie de session (jamais exposée, jamais commitée)
# Génère-en une : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=une-chaine-aleatoire-de-64-caracteres-minimum

# ── EmailJS (optionnel) ───────────────────────────────────────────────────────
# Clé publique EmailJS — peut être exposée côté client (NEXT_PUBLIC_)
NEXT_PUBLIC_EMAILJS_KEY=ta-cle-emailjs
